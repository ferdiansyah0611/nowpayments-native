{
  "name": "nowpayments-native",
  "version": "2.0.0",
  "description": "A type-safe, dependency-free TypeScript client for the NowPayments.io API.",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:resources": "vitest run test/resources",
    "test:e2e": "vitest run test/e2e"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^20.19.43",
    "dotenv": "^17.4.2",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
